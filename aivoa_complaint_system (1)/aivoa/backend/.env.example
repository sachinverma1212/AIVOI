# Copy this file to .env and fill in real values.

# Groq API key - create one at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_EXTRACTION_MODEL=gemma2-9b-it
GROQ_REASONING_MODEL=llama-3.3-70b-versatile

# Database - Postgres example:
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/aivoa
# MySQL example:
# DATABASE_URL=mysql+pymysql://root:root@localhost:3306/aivoa
# Leave unset to use a local SQLite file (zero setup, good for quick demo).
DATABASE_URL=sqlite:///./aivoa_dev.db

CORS_ORIGINS=http://localhost:3000
